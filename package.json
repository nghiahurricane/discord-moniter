{
  "name": "tool-discord",
  "version": "2.5.9",
  "description": "Discord Monitor Launcher Pro",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder -w"
  },
  "build": {
    "appId": "com.discord.monitor",
    "productName": "DiscordMonitor",
    "publish": [
      {
        "provider": "github",
        "owner": "nghiahurricane",
        "repo": "discord-moniter",
        "releaseType": "release"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "debug": "^4.4.3",
    "discord.js-selfbot-v13": "^3.7.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  }
}
